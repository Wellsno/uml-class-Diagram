    + nextOrderId(orderDAO: OrderDAO): String
  }
  class UserAccountUtils <<utility>> {
    + normalizeEmail(email: String): String
    + isValidEmail(email: String): boolean
  }

  OrderIdGenerator ..> OrderDAO : uses
}

